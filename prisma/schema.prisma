// PegadaCerta – Prisma schema para TiDB Cloud (MySQL compatível)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── NextAuth obrigatórios ────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuários ─────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TRAINER
  CLIENT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  role          UserRole  @default(TRAINER)
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  trainer  Trainer?
  client   Client?
}

// ─── Adestrador ───────────────────────────────────────────────────────────────

model Trainer {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  plan        String    @default("Trial")
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())

  clients         ClientProfile[]
  trainingSessions TrainingSession[]
  calendarEvents  CalendarEvent[]
  payments        Payment[]

  @@index([userId])
}

// ─── Cliente/Tutor ────────────────────────────────────────────────────────────

model Client {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profiles ClientProfile[]

  @@index([userId])
}

model ClientProfile {
  id             String   @id @default(cuid())
  trainerId      String
  trainer        Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  propertyType   String?
  environment    String?  @db.Text
  plan           String?
  contractAmount Float    @default(0)
  billingDay     Int      @default(10)
  paymentMethod  String   @default("Pix")
  nextChargeDate String?
  createdAt      DateTime @default(now())

  dogs     Dog[]
  payments Payment[]

  clientUserId String?
  clientUser   Client? @relation(fields: [clientUserId], references: [id])

  @@index([trainerId])
  @@index([clientUserId])
}

// ─── Cão ──────────────────────────────────────────────────────────────────────

model Dog {
  id            String        @id @default(cuid())
  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name          String
  breed         String?
  age           String?
  weight        String?
  photoUrl      String?
  trainingTypes String        @db.Text // JSON serializado

  sessions TrainingSession[]

  @@index([clientId])
}

// ─── Sessão de treino ─────────────────────────────────────────────────────────

model TrainingSession {
  id          String   @id @default(cuid())
  trainerId   String
  trainer     Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  dogId       String?
  dog         Dog?     @relation(fields: [dogId], references: [id])
  clientName  String?
  dogName     String?
  number      Int      @default(1)
  title       String
  date        String
  notes       String   @db.LongText // JSON serializado
  createdAt   DateTime @default(now())

  @@index([trainerId])
  @@index([dogId])
}

// ─── Evento de calendário ─────────────────────────────────────────────────────

model CalendarEvent {
  id            String   @id @default(cuid())
  trainerId     String
  trainer       Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  day           String
  time          String
  dog           String
  client        String
  plan          String?
  sessionNumber Int      @default(1)
  status        String   @default("Confirmado")
  createdAt     DateTime @default(now())

  @@index([trainerId])
}

// ─── Pagamento ────────────────────────────────────────────────────────────────

model Payment {
  id            String   @id @default(cuid())
  trainerId     String
  trainer       Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId      String?
  clientProfile ClientProfile? @relation(fields: [clientId], references: [id])
  clientName    String
  amount        Float
  status        String   @default("Pendente")
  source        String?
  paymentMethod String?
  dueDate       String?
  reference     String?
  createdAt     DateTime @default(now())

  @@index([trainerId])
  @@index([clientId])
}
