// Adestro – Prisma schema para TiDB Cloud (MySQL compatível)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─── NextAuth obrigatórios ────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Usuários ─────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TRAINER
  CLIENT
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  role          UserRole  @default(TRAINER)
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  trainer  Trainer?
  client   Client?
}

// ─── Adestrador ───────────────────────────────────────────────────────────────

model Trainer {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  plan        String    @default("Trial")
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())

  clients         ClientProfile[]
  trainingSessions TrainingSession[]
  calendarEvents  CalendarEvent[]
  payments        Payment[]
  portalTasks     PortalTask[]
  portalFeedbacks PortalFeedback[]
  portalAccessLinks PortalAccessLink[]
  clientGamifications ClientGamification[]
  renewals        SubscriptionRenewal[]

  @@index([userId])
}

model SubscriptionRenewal {
  id            String   @id @default(cuid())
  trainerId     String
  trainer       Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  planName      String
  lessonPackage String
  paymentMethod String
  amount        Float
  status        String   @default("Gerada")
  reference     String?
  dueDate       String?
  createdAt     DateTime @default(now())

  @@index([trainerId])
}

// ─── Cliente/Tutor ────────────────────────────────────────────────────────────

model Client {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  profiles ClientProfile[]

  @@index([userId])
}

model ClientProfile {
  id             String   @id @default(cuid())
  trainerId      String
  trainer        Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  propertyType   String?
  environment    String?  @db.Text
  plan           String?
  createdAt      DateTime @default(now())

  dogs     Dog[]
  calendarEvents CalendarEvent[]
  portalTasks     PortalTask[]
  portalFeedbacks PortalFeedback[]
  portalAccessLink PortalAccessLink?
  gamification    ClientGamification?

  clientUserId String?
  clientUser   Client? @relation(fields: [clientUserId], references: [id])

  @@index([trainerId])
  @@index([clientUserId])
}

// ─── Cão ──────────────────────────────────────────────────────────────────────

model Dog {
  id            String        @id @default(cuid())
  clientId      String
  client        ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name          String
  breed         String?
  age           String?
  weight        String?
  photoUrl      String?
  trainingTypes String        @db.Text // JSON serializado

  sessions TrainingSession[]
  calendarEvents CalendarEvent[]

  @@index([clientId])
}

// ─── Sessão de treino ─────────────────────────────────────────────────────────

model TrainingSession {
  id          String   @id @default(cuid())
  trainerId   String
  trainer     Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  dogId       String?
  dog         Dog?     @relation(fields: [dogId], references: [id])
  clientName  String?
  dogName     String?
  number      Int      @default(1)
  title       String
  date        String
  notes       String   @db.LongText // JSON serializado
  media       String?  @db.LongText // JSON serializado de imagens comprimidas
  createdAt   DateTime @default(now())

  @@index([trainerId])
  @@index([dogId])
}

// ─── Evento de calendário ─────────────────────────────────────────────────────

model CalendarEvent {
  id            String   @id @default(cuid())
  trainerId     String
  trainer       Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId      String?
  clientProfile ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  dogId         String?
  dogProfile    Dog?     @relation(fields: [dogId], references: [id], onDelete: SetNull)
  day           String
  time          String
  dog           String
  client        String
  plan          String?
  sessionNumber Int      @default(1)
  status        String   @default("Confirmado")
  createdAt     DateTime @default(now())

  @@index([trainerId])
  @@index([clientId])
  @@index([dogId])
}

// ─── Pagamento ────────────────────────────────────────────────────────────────

model Payment {
  id            String   @id @default(cuid())
  trainerId     String
  trainer       Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  description   String
  amount        Float
  status        String   @default("Pendente")
  paymentMethod String?
  dueDate       String?
  reference     String?
  createdAt     DateTime @default(now())

  @@index([trainerId])
}

// ─── Tarefa do portal ─────────────────────────────────────────────────────────

model PortalTask {
  id          String   @id @default(cuid())
  trainerId   String
  trainer     Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId    String?
  client      ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  title       String
  description String?  @db.Text
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([trainerId])
  @@index([clientId])
}

// ─── Feedback do portal ───────────────────────────────────────────────────────

model PortalFeedback {
  id        String   @id @default(cuid())
  trainerId String
  trainer   Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId  String?
  client    ClientProfile? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  author    String   @default("Tutor")
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([trainerId])
  @@index([clientId])
}

// ─── Link mágico do portal do tutor ──────────────────────────────────────────

model PortalAccessLink {
  id          String   @id @default(cuid())
  trainerId   String
  trainer     Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  clientId    String   @unique
  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  pinHash     String?
  tokenPrefix String
  expiresAt   DateTime
  revokedAt   DateTime?
  lastAccessAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([trainerId])
  @@index([expiresAt])
  @@index([revokedAt])
}

// ─── Gamificação do cliente ───────────────────────────────────────────────

model ClientGamification {
  id                      String   @id @default(cuid())
  clientId                String   @unique
  client                  ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  trainerId               String
  trainer                 Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  points                  Int      @default(0)
  streakDays              Int      @default(0)
  lastVisitDate           String?  // YYYY-MM-DD
  trainerRating           Int      @default(0)
  totalTasksCompleted     Int      @default(0)
  totalFeedbacks          Int      @default(0)
  totalTrainingsCompleted Int      @default(0)
  totalFeedbacksReceived  Int      @default(0)
  tutorsInvited           Int      @default(0)
  weeklyTasksCompleted    Int      @default(0)
  successfulTrainings     Int      @default(0)
  videosShared            Int      @default(0)
  monthlyProgress         Int      @default(0)
  watchedVideos           String   @db.Text
  sessionRatings          String   @db.Text
  techniquesUsed          String   @db.Text @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([trainerId])
}
